{
  "name": "indret-theme-js-tests",
  "version": "1.0.0",
  "description": "Jest tests for InDret theme JS",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jquery": "^3.7.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": [
      "./setup.js"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "../../js/advanced-search.js"
    ]
  }
}
